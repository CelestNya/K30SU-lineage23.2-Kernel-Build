diff --git a/drivers/staging/qcacld-3.0/Kbuild b/drivers/staging/qcacld-3.0/Kbuild
index 65afd5749..c5f299aab 100644
--- a/drivers/staging/qcacld-3.0/Kbuild
+++ b/drivers/staging/qcacld-3.0/Kbuild
@@ -55,7 +55,17 @@ $(warning "Overriding WLAN config with: $(shell cat $(WLAN_CFG_OVERRIDE_FILE))")
 endif

+CONFIG_ROME_IF = pci
+
 include $(WLAN_ROOT)/configs/$(patsubst "%",%,$(CONFIG_QCA_CLD_WLAN_PROFILE))_defconfig
+# In in-tree builds the CNSS2/ROME_IF chain does not propagate; pre-set
+# ROME_IF so that PCI-related conditionals (ATH_11AC_TXCOMPACT, etc.)
+# within the profile defconfig fire correctly.
+# Also force HIF_PCI and WLAN_FEATURE_11W since their profile conditions
+# depend on CONFIG_CNSS2 from the kernel .config which may not propagate
+# either directly or through the ROME_IF chain.
+CONFIG_HIF_PCI := y
+CONFIG_WLAN_FEATURE_11W := y

 ############ UAPI ############
 UAPI_DIR :=	uapi
